generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Barberia {
  id            Int            @id @default(autoincrement())
  nombre        String
  codigo        String         @unique
  logo          String?
  createdAt     DateTime       @default(now())
  usuarios      Usuario[]
  barberos      Barbero[]
  servicios     Servicio[]
  reservas      Reserva[]
  horarios      Horario[]
  configuracion Configuracion?
}

model Usuario {
  id               Int       @id @default(autoincrement())
  nombre           String
  email            String    @unique
  password         String
  rol              String    @default("cliente")
  telefono         String?
  foto_url         String?   @db.LongText
  fecha_nacimiento DateTime?
  pushToken        String?
  barberiaId       Int?
  barberia         Barberia? @relation(fields: [barberiaId], references: [id])
  reservas         Reserva[]
  createdAt        DateTime  @default(now())
}

model Barbero {
  id           Int       @id @default(autoincrement())
  nombre       String
  especialidad String
  foto         String?
  categorias   String    @default("Cabello")
  barberiaId   Int
  barberia     Barberia  @relation(fields: [barberiaId], references: [id])
  reservas     Reserva[]
  horarios     Horario[]
}

model Servicio {
  id               Int       @id @default(autoincrement())
  nombre           String
  precio           Float
  duracion_minutos Int
  categoria        String    @default("General")
  activo           Boolean   @default(true)
  predefinido      Boolean   @default(false)
  barberiaId       Int
  barberia         Barberia  @relation(fields: [barberiaId], references: [id])
  reservas         Reserva[]
}

model Reserva {
  id         Int      @id @default(autoincrement())
  usuario    Usuario  @relation(fields: [usuarioId], references: [id])
  usuarioId  Int
  barbero    Barbero  @relation(fields: [barberoId], references: [id])
  barberoId  Int
  servicio   Servicio @relation(fields: [servicioId], references: [id])
  servicioId Int
  barberiaId Int
  barberia   Barberia @relation(fields: [barberiaId], references: [id])
  fecha      DateTime
  estado     String   @default("pendiente")
  notif15    Boolean  @default(false)
  notif5     Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Horario {
  id          Int      @id @default(autoincrement())
  barbero     Barbero  @relation(fields: [barberoId], references: [id])
  barberoId   Int
  barberiaId  Int
  barberia    Barberia @relation(fields: [barberiaId], references: [id])
  dia_semana  Int
  hora_inicio String
  hora_fin    String

  @@unique([barberoId, dia_semana])
}

model Configuracion {
  id                 Int      @id @default(autoincrement())
  nombre_barberia    String   @default("The Barber")
  moneda             String   @default("COP")
  simbolo            String   @default("$")
  separador_miles    String   @default(".")
  separador_decimal  String   @default(",")
  duracion_turno     Int      @default(30)
  dias_descanso      String   @default("")
  mensaje_bienvenida String?
  barberiaId         Int      @unique
  barberia           Barberia @relation(fields: [barberiaId], references: [id])
}
